# Newsletter pipeline config — SERVER-SIDE ONLY (used by scripts/ingest.mjs).
# Never prefix with VITE_ : that would bundle the key into the public browser JS.
# Copy this file to .env and fill in your key.

# OpenAI API key that powers headline + summary writing and story clustering.
OPENAI_API_KEY=

# Writing model: gpt-4o (best quality) or gpt-4o-mini (cheaper/faster).
OPENAI_MODEL=gpt-4o

# Embedding model used to detect the same story across multiple sources.
OPENAI_EMBED_MODEL=text-embedding-3-small

# Clustering sensitivity (cosine similarity to merge). Higher = stricter.
CLUSTER_THRESHOLD=0.62

# Auto-runner interval in minutes (npm run news:auto).
INGEST_INTERVAL_MIN=60

# Optional: where the published per-category JSON lives (production / CDN).
# Leave unset locally — the site reads /data/newsletter/<category>.json.
# VITE_NEWS_BASE_URL=https://www.shortlyindia.com/data/newsletter
